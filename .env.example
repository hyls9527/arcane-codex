# LM Studio API endpoint (default: localhost:1234)
LM_STUDIO_URL=http://127.0.0.1:1234

# AI model name (optional, auto-detected if blank)
LM_STUDIO_MODEL=

# Database path (default: app data directory)
DATABASE_URL=

# Thumbnail storage path (default: app data directory)
THUMBNAIL_DIR=

# Log level: trace, debug, info, warn, error
LOG_LEVEL=info

# AI processing concurrency (default: 3)
AI_CONCURRENCY=3

# Image deduplication similarity threshold (0-100, default: 90)
DEDUP_THRESHOLD=90
